# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Used in Stripe success/cancel URLs when deployed (include scheme, no trailing slash)
# PUBLIC_BASE_URL=https://your-app.example.com

# Optional: SQLite path (Docker compose sets /app/data/db.sqlite3)
# SQLITE_PATH=/app/data/db.sqlite3

# Stripe test keys — USD account (Dashboard in default or USD test mode)
STRIPE_SECRET_KEY_USD=sk_test_...
STRIPE_PUBLISHABLE_KEY_USD=pk_test_...

# Stripe test keys — separate EUR test account (or same account if you only use one)
STRIPE_SECRET_KEY_EUR=sk_test_...
STRIPE_PUBLISHABLE_KEY_EUR=pk_test_...
